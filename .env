# Configurações do MongoDB (Credenciais de Root)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=sua_senha_segura

# Variáveis que o seu código Rust lê
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=sua_senha_segura
MONGO_DATABASE=profile_service

# Configurações do Serviço
REQUEST_HOST=http://localhost:3000
SERVICE_ADDR=0.0.0.0:3000
